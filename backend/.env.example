# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens — use a long, random string in production
JWT_SECRET=your_jwt_secret_key_here

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
# RPC endpoint for Soroban smart contracts
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org (when available)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network name used by the Stellar SDK (testnet | mainnet)
NETWORK=testnet

# ─── Smart Contract IDs ───────────────────────────────────────────────────────
# Deployed contract addresses on the Stellar network
# Run the deploy script (soroban-contracts/deploy.sh) to generate these
REPUTATION_CONTRACT_ID=<reputation_contract_id>
EVENT_CONTRACT_ID=<event_contract_id>
PROJECT_CONTRACT_ID=<project_contract_id>
WALLET_REGISTRY_CONTRACT_ID=<wallet_registry_contract_id>

# ─── Platform Keypairs ────────────────────────────────────────────────────────
# Stellar secret keys for the admin and platform accounts
# NEVER commit real secret keys to version control
# Generate with: stellar keys generate admin --network testnet
ADMIN_SECRET=S...your_admin_stellar_secret_key
PLATFORM_SECRET=S...your_platform_stellar_secret_key

# ─── Wallet Encryption ────────────────────────────────────────────────────────
# Key used to encrypt/decrypt custodial wallet secrets stored in DB
# Use a strong, random string — at least 32 characters
WALLET_ENCRYPTION_KEY=your_wallet_encryption_key_here


# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000

RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_MS=3600000

RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Base URL of the frontend app — used to build deep-link CTA URLs in emails
FRONTEND_URL=http://localhost:3001

# ─── Transactional Email (Resend) ─────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
# Verify your sending domain before going to production
# If not set, email delivery is skipped with a warning log (platform still works)
RESEND_API_KEY=re_...your_resend_api_key
EMAIL_FROM=notificaciones@nuup.io
EMAIL_FROM_NAME=Nuup
