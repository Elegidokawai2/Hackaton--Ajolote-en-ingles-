# ─── Stellar / Soroban ────────────────────────────────────────────────────────
# RPC endpoint for Soroban smart contracts
# Testnet: https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network name used by the Stellar CLI (testnet | mainnet)
NETWORK=testnet

# ─── Deployed Contract IDs ────────────────────────────────────────────────────
# Run the deploy script (deploy.sh or deploy.bat) to obtain these values.
# They are output at the end of the script and also written to .env automatically.
REPUTATION_CONTRACT_ID=<reputation_contract_id>
EVENT_CONTRACT_ID=<event_contract_id>
PROJECT_CONTRACT_ID=<project_contract_id>
WALLET_REGISTRY_CONTRACT_ID=<wallet_registry_contract_id>

# ─── Platform Keypairs ────────────────────────────────────────────────────────
# Stellar secret keys for the admin and platform accounts.
# These must match the accounts configured in the Stellar CLI:
#   stellar keys generate admin --network testnet
#   stellar keys generate platform --network testnet
# NEVER commit real secret keys to version control.
ADMIN_SECRET=S...your_admin_stellar_secret_key
PLATFORM_SECRET=S...your_platform_stellar_secret_key

# ─── Wallet Encryption ────────────────────────────────────────────────────────
# Key used by the backend to encrypt custodial wallet secrets.
# Must match the WALLET_ENCRYPTION_KEY set in backend/.env.
WALLET_ENCRYPTION_KEY=your_wallet_encryption_key_here
